#!/usr/bin/make -f

%:
	dh $@

# DKMS modules are compiled at install time on the target, not at package
# build time. Disable the auto build/test/install/clean steps (which would
# otherwise invoke the kernel build system here).
override_dh_auto_build:
override_dh_auto_test:
override_dh_auto_install:
override_dh_auto_clean:
